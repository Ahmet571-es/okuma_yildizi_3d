# Yıldız Ülkesi - API Anahtarları
# Bu dosyayı .env olarak kopyalayın ve kendi API anahtarlarınızı girin

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Google Cloud TTS (PRIMARY - 1M karakter/ay ücretsiz)
GOOGLE_TTS_API_KEY=xxxxxxxxxxxxxxxxxxxxx
GOOGLE_TTS_VOICE=tr-TR-Wavenet-A

# ElevenLabs TTS (FALLBACK)
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID=xxxxxxxxxxxxxxxxxxxxx

# Sunucu Ayarları
PORT=3001
NODE_ENV=development
